# Copy file này thành .env.local để chạy local
# Trên Vercel, set biến này trong Project Settings > Environment Variables
VITE_API_URL=http://localhost:3000

# Google OAuth Client ID
# Tạo tại: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
